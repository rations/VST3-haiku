# Style for code WE author in this repo (hosts/, plugins/*/source/). Matches the sibling
# jackDAW-haiku project: 4-space indentation, Linux braces (function brace on its own line,
# control braces attached), no tabs.
#
# NEVER run clang-format over imported upstream trees (vst3sdk/, plugins/*/deps/) — Haiku
# patches inside them match the surrounding Steinberg/upstream style by hand.
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
BreakBeforeBraces: Linux
PointerAlignment: Right
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
SortIncludes: false
IndentCaseLabels: true
AccessModifierOffset: -4
